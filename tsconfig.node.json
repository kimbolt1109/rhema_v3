{
  "$schema": "https://json.schemastore.org/tsconfig",
  "//": "Node/Electron side: main process, preload bridge, shared protocol, and the build tooling configs. Checked by `npm run typecheck:node`.",
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "types": ["node"]
  },
  "include": [
    "src/main/**/*.ts",
    "src/preload/**/*.ts",
    "src/shared/**/*.ts",
    "electron.vite.config.ts",
    "vitest.config.ts"
  ],
  "exclude": ["node_modules", "out", "release", "dist"]
}

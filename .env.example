# ─────────────────────────────────────────────────────────────────────────────
# Verger environment contract
#
# Copy this file to `.env` and fill in what you have. `.env` is gitignored —
# never commit real values, and never paste a secret into any other file.
#
# THE CONTRACT: an EMPTY value means that subsystem runs in
# "not configured" / degraded mode. It reports its state in the UI and NEVER
# crashes the app. No key in this file is required for Verger to start.
#
# Every key name here must exist in `src/shared/config.ts` (EnvKey) and vice
# versa. If you add a key to one, add it to the other in the same commit.
# ─────────────────────────────────────────────────────────────────────────────


# --- OBS Studio (Phase 1) ---------------------------------------------------
# obs-websocket v5, enabled in OBS via Tools -> WebSocket Server Settings.
# URL form: ws://127.0.0.1:4455 . Empty URL => the OBS panel shows
# "Not configured" and the reconnect loop stays idle instead of dialling.
# Empty password is VALID and means "OBS has authentication disabled".
OBS_WEBSOCKET_URL=
OBS_WEBSOCKET_PASSWORD=


# --- YouTube Live / Google OAuth (Phases 4-5) -------------------------------
# Google Cloud project -> YouTube Data API v3 -> OAuth client of type "Desktop".
# The refresh token is NOT stored here; it goes to Electron safeStorage after
# the first loopback OAuth. Empty => the Go Live screen shows "Not connected"
# and every YouTube action is disabled rather than failing mid-service.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# --- Speech-to-text (Phase 7) -----------------------------------------------
# Cloud ASR (default provider). Empty => Verger falls back to the local
# faster-whisper adapter, and if that is unavailable the cue engine degrades
# to fully manual operation. It never blocks the operator.
DEEPGRAM_API_KEY=


# --- Scripture providers (Phase 8) ------------------------------------------
# Copyrighted translations are fetched live from a licensed API with
# attribution — they are never bundled into this repo. Empty => only
# verified public-domain translations are available.
ESV_API_KEY=
API_BIBLE_KEY=


# --- Crash reporting (Phase 9) ----------------------------------------------
# Empty => crash reporting is off. No telemetry leaves the machine.
SENTRY_DSN=
